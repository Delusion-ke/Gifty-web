{
  "rewrites": [
    { "source": "/wish/:id",        "destination": "/wish/index.html" },
    { "source": "/privacy",         "destination": "/privacy/index.html" },
    { "source": "/terms",           "destination": "/terms/index.html" },
    { "source": "/cookies",         "destination": "/cookies/index.html" },
    { "source": "/u/:giftyId",      "destination": "/u/index.html" },
    { "source": "/invite/:uid",     "destination": "/invite/index.html" },
    { "source": "/delete-account",  "destination": "/delete-account/index.html" },
    { "source": "/admin",           "destination": "/admin/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ]
}
