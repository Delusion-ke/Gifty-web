{
  "expo": {
    "name": "Gifty",
    "slug": "gifty",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gifty",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F7FB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gifty.app",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDisplayName": "Gifty",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:gifty.cloud"
      ]
    },
    "android": {
      "package": "com.gifty.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1020"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "gifty.cloud",
              "pathPrefix": "/wish"
            },
            {
              "scheme": "https",
              "host": "gifty.cloud",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F7FB",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ca7b6529-73d4-4521-9944-d0e2a5315ecc"
      }
    },
    "owner": "delusion-ke"
  }
}
